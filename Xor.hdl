// File name: projects/1/Xor.hdl
/**
 * Exclusive-or gate:
 * if ((a and Not(b)) or (Not(a) and b)) out = 1, else out = 0
 */
CHIP Xor {
    IN a, b;
    OUT out;

    PARTS:
    Not(in=a , out=NotA );
    Not(in=b , out=NotB );
    And(a=a , b=NotB , out=OutAnd1);
    And(a=NotA , b=b , out=OutAnd2);
    Or(a=OutAnd1 , b= OutAnd2, out=out );
}